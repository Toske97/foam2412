FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 345;

boundaryField
{

    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }

   "(top|front|back)"
    {
        type            symmetry;
    }

    bottom
    {
        type            epsilonWallFunction;
        value           $internalField;
    }

    ahmed
    {
        type            epsilonWallFunction;
        value           $internalField;
    }
 
}


