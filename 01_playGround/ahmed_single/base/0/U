FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (40.0 0.0 0.0 );

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (40 0 0);
    }

    outlet
    {
        type            inletOutlet;
        value           uniform (0 0 0);
        inletValue      uniform (0 0 0);
    }

    "(top|front|back)"
    {
        type            symmetry;
    }

    bottom
    {
        type            movingWallVelocity;
        value           uniform (40 0 0);
    }

    ahmed
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

}


